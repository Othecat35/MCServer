#!/usr/bin/env python3
__version__ = "1.5.0"

import argparse
import json
import math
import os
import sys
import shutil
import textwrap
import time

import urllib.parse
import urllib.request

import logging as log

from pathlib import Path

# Variables
user_agent = "othecat35/MCServer"

default_configs = {
  "launcher": {
     "ram": {
      "_comment": "Memory size in MebiByte (MiB)",
      "min": 512,
      "max": 2_048
    },

    "jarfile": "Launcher.jar",
    "hide_gui": True,
 },

  "modrinth": {
    "search_limit": 20
  },

  "server": {
    "version": "1.21.11",
    "loader": {
      "name": "fabric",
      "version": "0.18.4"
    }
  }
}

# Paths
mcserver_dir = Path(".mcserver")

configs_dir = mcserver_dir / "configs"
tempfiles_dir = mcserver_dir / "tempfiles"

# Error classes
class EULAAgreementError(Exception): pass

# Color functions
colors = {
  "bold": "\033[1m",
  "gray": "\033[90m",
  "green": "\033[92m",
  "red": "\033[91m",
  "reset": "\033[0m",
  "yellow": "\033[93m"
}

def color(color_name):
  if sys.stdout.isatty() and sys.stderr.isatty():
    return colors[color_name]
  else:
    return ""

def color_text(text, color_name):
  return f"{color(color_name)}{text}{color('reset')}"

def mod_environment_color(environment):
  if environment == "required":
    return color_text("Required", "green")

  elif environment == "optional":
    return color_text("Optional", "yellow")

  elif environment == "unsupported":
    return color_text("Unsupported", "red")

  elif environment == "unknown":
    return color_text("Unknown", "gray")

  else:
    return environment

# Config functions
def generate_config(config_name):
  config_filename = f"{config_name}.json"
  config_path = configs_dir / config_filename

  config_content = None
  try:
    config_content = default_config[config_name]
  except KeyError as error:
    raise ValueError(f"Cannot generate configuration file for '{config_name}': Default configuration not available") from error

  try:
    with open(config_path, mode="xt") as config_file:
      json.dump(
        config_content,
        config_file,
        indent=2
      )
  except FileExistsError as error:
    raise FileExistsError(f"Cannot generate configuration file for '{config_name}': Configuration file already exists") from error
  except FileNotFoundError as error:
    raise FileNotFoundError(f"Cannot generate configuration file for '{config_name}': Configuration directory does not exist") from error
  except IsADirectoryError as error:
    raise IsADirectoryError(f"Cannot generate configuration file for '{config_name}': Directory with same name already exists") from error
  except PermissionError as error:
    raise PermissionError(f"Cannot generate configuration file for '{config_name}': Permission denied to create a file") from error

def load_config(config_name):
  config_filename = f"{config_name}.json"
  config_path = configs_dir / config_filename

  try:
    with open(config_path, mode="rt") as config_file:
      return json.load(config_file)
  except json.JSONDecodeError as error:
    msg = error.msg.lower()
    lineno = error.lineno
    colno = error.colno

    raise ValueError(f"Failed to parse configuration for `{config_name}`: {msg} at line {lineno} column {colno}") from error
  except FileNotFoundError as error:
    raise FileNotFoundError(f"Cannot load configuration file for '{config_name}': Configuration file does not exist") from error
  except IsADirectoryError as error:
    raise IsADirectoryError(f"Cannot load configuration file for '{config_name}': Is a directory") from error
  except PermissionError as error:
    raise PermissionError(f"Cannot load configuration file for '{config_name}': Permission denied to read file") from error

# Requests
def request_get(url, params=None, headers=None):
  if params is None: params = {}
  if headers is None: headers = {}
  headers.setdefault("User-Agent", user_agent)

  query_string = f"?{urllib.parse.urlencode(params)}" if params else ""
  log.debug(f"Query string: {query_string}")

  request_url = urllib.request.Request(f"{url}{query_string}", headers=headers, method="GET")
  log.debug(f"Request URL: {request_url.full_url}")

  with urllib.request.urlopen(request_url) as response:
    return response.read().decode("utf-8")

def request_download(url, filename, headers=None):
  if headers is None: headers = {}
  headers.setdefault("User-Agent", user_agent)

  request_url = urllib.request.Request(f"{url}", headers=headers, method="GET")
  tempfile = tempfiles_dir / filename

  log.debug(f"Request URL: {request_url.full_url}")
  with urllib.request.urlopen(request_url) as response:
    with open(tempfile, mode="wb") as file:
      shutil.copyfileobj(response, file)

    shutil.move(tempfile, filename)

# EULA functions
def check_eula_agreed():
  try:
    with open("eula.txt") as file:
      for line in file.read().split("\n"):
        if line.startswith("eula=true"):
            return True
  except FileNotFoundError:
    pass

  return False

def eula_agree():
  timestamp = time.strftime("%a %b %d %H:%M:%S GMT %Y", time.gmtime())
  with open("eula.txt", mode="wt") as file:
    file.write(f"""#By changing the setting below to TRUE you are indicating your agreement to our EULA (https://aka.ms/MinecraftEULA).
#{timestamp}
eula=true""")

# Functions
def wrap_text(text, initial_indent="", subsequent_indent=""):
  terminal_width = shutil.get_terminal_size().width
  return "\n".join(textwrap.wrap(text, width=terminal_width, initial_indent=initial_indent, subsequent_indent=subsequent_indent))


# Command functions
def initialize_directory(args):
  if not mcserver_dir.exists():
    log.info(f"Initializing MCServer directory at {mcserver_dir.resolve()}")
  else:
    log.info(f"Reinitializing MCServer directory at {mcserver_dir.resolve()}")

  mcserver_dir.mkdir(exist_ok=True)

  configs_dir.mkdir(exist_ok=True)
  tempfiles_dir.mkdir(exist_ok=True)

  for config in default_configs.keys():
    try:
      generate_config(config)
    except FileExistsError:
      log.debug(f"Configuration file for `{config}` already exists, not regenerating")

def install_server(args):
  server_config = load_config("server")
  launcher_config = load_config("launcher")

  server_loader = server_config["loader"]

  server_version = server_config["version"]
  loader_version = server_loader["version"]

  if server_loader["name"] == "fabric":
    log.info(f"Downloading jarfile for Minecraft {server_version} (Fabric {loader_version})...")
    request_download(f"https://meta.fabricmc.net/v2/versions/loader/{server_version}/{loader_version}/1.1.1/server/jar", launcher_config["jarfile"])

  log.info("Done")

def search_mod(args):
  query = " ".join(args.query)
  no_filter = args.no_filter
  page = args.page

  modrinth_config = load_config("modrinth")
  server_config = load_config("server")

  server_loader = server_config["loader"]
  if not no_filter and server_loader["name"] == "vanilla":
    raise Exception("Vanilla Minecraft server does not support mod")

  server_version = server_config["version"]
  loader_version = server_loader["version"]

  search_limit = modrinth_config["search_limit"]
  search_offset = search_limit * (page - 1)

  search_filters = None
  search_message = None

  if no_filter:
    search_message = "Searching mods in Modrinth..."
    search_filters = [["project_type:mod"]]
  else:
    search_message = f"Searching mods in Modrinth for {server_loader['name'].capitalize()}, Minecraft server {server_version}..."
    search_filters = [
      ["project_type:mod"],
      ["server_side!=unsupported"],
      [f"categories:{server_loader['name']}"],
      [f"versions:{server_version}"]
    ]

  facets = json.dumps(search_filters)
  log.info(search_message)

  response = request_get(
    "https://api.modrinth.com/v2/search",
    {
      "query": query,
      "facets": facets,
      "limit": search_limit,
      "offset": search_offset
    }
  )

  response_json = json.loads(response)
  mods_list = response_json.get("hits", [])

  if not mods_list:
    raise Exception(f"No mod found")

  total_hits = response_json.get("total_hits", 0)
  shown_mods_count = len(mods_list) if len(mods_list) < search_limit else search_limit

  skipped_message = f"(skipped {search_offset} mods) " if search_offset > 1 else ""
  log.info(f"Showing {shown_mods_count} mods out of {total_hits} total mods {skipped_message}| Page: {page}/{math.ceil(total_hits/search_limit)}")

  for mod in mods_list:
    title = color_text(mod['title'], "bold")
    slug = mod["slug"]

    author = mod["author"]

    server_side = mod_environment_color(mod["server_side"])
    client_side = mod_environment_color(mod["client_side"])
    description = wrap_text(mod["description"], initial_indent=" ", subsequent_indent="  ")

    print(f"""
{title} ({slug}) {color("gray")}by {author}{color('reset')}
> {color('bold')}Server: {server_side}{color('reset')} | Client: {client_side}
> https://modrinth.com/mod/{slug}
{description}""")

def show_mod(args):
  modid = args.modid[0]

  log.info("Getting mod info...")
  mod_info = json.loads(request_get(
    f"https://api.modrinth.com/v2/project/{modid}",
  ))

  terminal_width, _ = os.get_terminal_size()
  log.debug(terminal_width)

  name = color_text(mod_info['title'], "bold")
  description = color_text(mod_info["description"], "bold")

  slug = color_text(mod_info["slug"], "bold")
  mod_id = color_text(mod_info["id"], "bold")

  downloads = color_text(f"{mod_info["downloads"]:,}", "bold")
  followers = color_text(f"{mod_info["followers"]:,}", "bold")

  categories = color_text(", ".join(entry.capitalize() for entry in mod_info["categories"]), "bold")
  loaders = color_text(", ".join(entry.capitalize() for entry in mod_info["loaders"]), "bold")
  mc_versions = wrap_text(f"Minecraft Versions {color_text(', '.join(mod_info['game_versions']), 'bold')}", subsequent_indent=" "))

  license_name = color_text(mod_info["license"]["name"], "bold")
  license_id = color_text(mod_info["license"]["id"], "bold")

  server_side = mod_environment_color(mod_info["server_side"])
  client_side = mod_environment_color(mod_info["client_side"])

  print(f"""Name: {name}
Slug/ID: {slug} ({mod_id})

Downloads: {downloads}
Followers: {followers}

Categories: {categories}
Loaders: {loaders}
Environment: Server: {server_side} | Client: {client_side}
{mc_versions}

License: {license_name} ({license_id})
Description: {description}""")

def start_server(args):
  launcher_config = load_config("launcher")
  memory_limit = launcher_config["ram"]

  jarfile = launcher_config['jarfile']

  if not Path(jarfile).exists():
    raise Exception(f"Couldn't find server jarfile '{jarfile}'")

  if memory_limit["min"] > memory_limit["max"]:
    raise Exception(f"Minimum RAM cannot be larger that maximum RAM, please check configuration for `server`")

  try:
    if not check_eula_agreed():
      log.warning("You need to agree to Mojang's EULA in order to run the server: https://aka.ms/MinecraftEULA")
      log.info(f"Type {color_text('Agree', 'yellow')} (case-sensitive) to agree with Mojang's EULA.")
      answer = input("> ")

      if answer == "Agree":
        eula_agree()
      else:
        raise EULAAgreementError("Failed to start the Minecraft server: EULA not agreed")
  except KeyboardInterrupt:
    raise EULAAgreementError("\nFailed to start the Minecraft server: EULA not agreed")

  java_command_argv = [
    "java",
    f"-Xms{memory_limit['min']}M",
    f"-Xmx{memory_limit['max']}M",
    "-jar",
    launcher_config["jarfile"]
  ]

  if launcher_config["hide_gui"]:
    java_command_argv.append("nogui")

  log.info("Starting Minecraft server...")
  log.debug(f"Executing command: {" ".join(java_command_argv)}")
  os.execvp("java", java_command_argv)

# Main
def main():
  debug_mode = os.getenv("MCSERVER_DEBUG") == "1"
  log_level = log.DEBUG if debug_mode else log.INFO

  log.basicConfig(
    format="[%(levelname)s]: %(message)s",
    level=log_level
  )

  parser = argparse.ArgumentParser()
  subparsers = parser.add_subparsers(required=True)

  # 'init' command
  parser_init = subparsers.add_parser("init", help="initialize MCServer directory")
  parser_init.set_defaults(func=initialize_directory)

  # 'install' command
  parser_install = subparsers.add_parser("install", help="install the server")
  parser_install.set_defaults(func=install_server)

  # 'search' command
  parser_search = subparsers.add_parser("search", help="search mods from Modrinth")
  parser_search.add_argument("query", help="search query", nargs="+")

  parser_search.add_argument("--no-filter", help="seach without version bounded", action="store_true")
  parser_search.add_argument("--page", help="page number of the search results", type=int, default=1)

  parser_search.set_defaults(func=search_mod)

  # 'show' command
  parser_show = subparsers.add_parser("show", help="show more info about a mod")
  parser_show.add_argument("modid", help="slug/mod ID", nargs="+")
  parser_show.set_defaults(func=show_mod)

  # 'start' command
  parser_start = subparsers.add_parser("start", help="start the server")
  parser_start.set_defaults(func=start_server)

  args = parser.parse_args()

  # Let it crash
  if debug_mode:
    args.func(args)
  else:
    try:
      args.func(args)
    except Exception as error:
      log.error(error)

if __name__ == "__main__": main()
