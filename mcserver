def print_help(args):
  parser = args.parser

  parser.print_help()
  sys.exit(0)

def wrap_text(text, initial_indent="", subsequent_indent=""):
  if isinstance(initial_indent, int):
    raise ValueError("initial_indent supposed to be a str, duh!")
  elif isinstance(subsequent_indent, int):
    raise ValueError("subsequent_indent supposed to be a str, duh!")

  terminal_width = shutil.get_terminal_size().columns
  return "\n".join(textwrap.wrap(text, width=terminal_width, initial_indent=initial_indent, subsequent_indent=subsequent_indent))

# Command functions
def add_mod(args):
  mods = args.mods

  server_config = load_config("server")
  server_loader = server_config["loader"]

  loader_name = server_loader["name"]
  server_version = server_config["version"]

  if server_loader["name"] == "vanilla":
    raise AddModError("Vanilla Minecraft server does not support mod.")

  log.info("Getting mod dependency(ies) information...")

  unresolved_dependencies = []
  resolved_dependencies = set()
  resolved_data = []

  for mod in mods:
    if mod in resolved_dependencies:
      continue

    log.debug(f"Getting version info of '{mod}'...")
    response = fetch_mod_version(mod, server_version, loader_name)

    data = response["data"]
    dependencies = response["dependencies"]

    data["type"] = "required"
    resolved_data.append(data)

    resolved_dependencies.add(mod) # Add slug/ID
    resolved_dependencies.add(data["id"]) # Only add ID

    for dependency in dependencies:
      unresolved_dependencies.append(dependency)
      log.debug(f"Added '{dependency['id']}' as unresolved {dependency['type']} dependency.")

  while unresolved_dependencies:
    resolving_dependency = unresolved_dependencies.pop(0)

    mod_id = resolving_dependency["id"]
    dependency_type = resolving_dependency["type"]

    if mod_id in resolved_dependencies:
      continue

    log.debug(f"Processing unresolved dependency '{mod_id}'...")
    resolved_dependencies.add(mod_id)

    if dependency_type == "embedded":
      log.debug("Skipped processing 'embedded' mod dependency")
      continue

    if dependency_type == "incompactible":
      log.info(f"Skipped mod {mod_id} because it is marked as incompactible.") # Keep it simple for now

    response = None

    try:
      response = fetch_mod_version(mod_id, server_version, loader_name)
    except FetchModVersionError:
      if dependency_type == "optional":
        log.warning(f"An optional dependency doesn't have version for {loader_name.capitalize()}, Minecraft {server_version}.") # We'll fetch info about that mod later
        continue

      raise AddModError(f"This mod contains dependency that doesn't have version for {loader_name.capitalize}, Minecraft {server_version}.")

    data = response["data"]
    dependencies = response["dependencies"]

    data["type"] = dependency_type
    resolved_data.append(data)

    for dependency in dependencies:
      mod_id = dependency["id"]
      if mod_id not in resolved_dependencies:
        unresolved_dependencies.append(dependency)
        log.debug(f"Added '{mod_id}' as unresolved {dependency['type']} dependency")

  # Get mod IDs
  mod_ids = []
  total_size = 0

  required_mod_ids = set()
  optional_mod_ids = set()

  for mod in resolved_data:
    if mod["type"] == "required":
      required_mod_ids.add(mod["id"])
    elif mod["type"] == "optional":
      optional_mod_ids.add(mod["id"])

    total_size += mod["file"]["size"]
    mod_ids.append(mod["id"])

  response = json.loads(request_fetch("https://api.modrinth.com/v2/projects", params={
    "ids": json.dumps(mod_ids)
  }))

  optional_modname_list = []
  required_modname_list = []

  for mod in response:
    if mod["id"] in required_mod_ids:
      required_modname_list.append(f"{mod['title']} ({mod['slug']})")
    elif mod['id'] in optional_mod_ids:
      optional_modname_list.append(f"{mod['title']} ({mod['slug']})")

  log.info("The mod(s) that are going to be downloaded:")
  print(wrap_text(", ".join(required_modname_list), initial_indent="  ", subsequent_indent="  "))

  if optional_mod_ids:
    log.info("The mod(s) that are optional:")
    print(wrap_text(", ".join(optional_modname_list), initial_indent="  ", subsequent_indent="  "))

  print()
  # log.info(f"Will download {total_size}B of mod(s) file.")

  continue_action = True
  answer = " "

  try:
    answer = input("Do you want to continue? [Y/n] ")
  except KeyboardInterrupt:
    continue_action = False

  match answer.lower():
    case "y" | "yes" | "":
      pass
    case "n" | "no" | _:
      continue_action = False

  if not continue_action:
    raise AddModError("Abort.")

  mods_dir.mkdir(exist_ok=True)
  for mod in resolved_data:
    if mod["type"] == "required":
      mod_file = mod["file"]

      log.info(f"Downloading version {mod['name']}...")
      request_download(mod_file["url"], mods_dir / mod_file["filename"])

def initialize_directory(args):
  if not mcserver_dir.exists():
    log.info(f"Initializing MCServer directory at {mcserver_dir.resolve()}")
  else:
    log.info(f"Reinitializing MCServer directory at {mcserver_dir.resolve()}")

  mcserver_dir.mkdir(exist_ok=True)

  configs_dir.mkdir(exist_ok=True)
  tempfiles_dir.mkdir(exist_ok=True)

  for config in default_configs.keys():
    try:
      generate_config(config)
    except FileExistsError:
      log.debug(f"Configuration file for `{config}` already exists, not regenerating")

def install_server(args):
  server_config = load_config("server")
  launcher_config = load_config("launcher")

  server_loader = server_config["loader"]

  server_version = server_config["version"]
  loader_version = server_loader["version"]

  if server_loader["name"] == "fabric":
    log.info(f"Downloading jarfile for Minecraft {server_version} (Fabric {loader_version})...")
    request_download(f"https://meta.fabricmc.net/v2/versions/loader/{server_version}/{loader_version}/1.1.1/server/jar", launcher_config["jarfile"])

  log.info("Done")

def search_mod(args):
  query = " ".join(args.query)

  no_filter = args.no_filter
  page = args.page

  modrinth_config = load_config("modrinth")
  server_config = None

  search_filters = None
  search_message = None

  if no_filter:
    search_message = f"Searching mods with \"{query}\" in Modrinth..."
    search_filters = [["project_type:mod"]]
  else:
    server_config = load_config("server")
    server_loader = server_config["loader"]

    server_version = server_config["version"]
    loader_name = server_loader["name"]

    if loader_name == "vanilla":
      raise SearchModError("Vanilla Minecraft server does not support mod")

    search_message = f"Searching mods with \"{query}\" in Modrinth for {loader_name.capitalize()}, Minecraft server {server_version}..."
    search_filters = [
      ["project_type:mod"],
      ["server_side!=unsupported"],
      [f"categories:{loader_name}"],
      [f"versions:{server_version}"]
    ]

  search_limit = modrinth_config["search_limit"]
  search_offset = search_limit * (page - 1)

  log.info(search_message)

  response = json.loads(request_fetch(
    "https://api.modrinth.com/v2/search",
    {
      "query": query,
      "facets": json.dumps(search_filters),
      "limit": search_limit,
      "offset": search_offset
    }
  ))

  mods_list = response.get("hits", [])
  if not mods_list:
    raise SearchModError(f"No mod found")

  total_hits = response.get('total_hits', 0)
  total_pages = math.ceil(total_hits / search_limit)

  response_offset = response.get("offset", 0)
  shown_mods_count = min(len(mods_list), search_limit)

  skipped_message = f"(skipped {response_offset} mod(s)) " if response_offset > 0 else ""
  log.info(f"Showing {shown_mods_count} mod(s) out of {total_hits} total mod(s) {skipped_message}| Page: {page}/{total_pages}")

  for mod in mods_list:
    title = color_text(mod.get("title", ""), "bold")
    slug = mod.get("slug", "")
    author = f"by {mod.get('author', '')}"

    mod_header = wrap_text(f"{title} ({slug}) {color_text(author, 'gray')}", subsequent_indent=" ")

    downloads_count = mod.get("downloads", 0)
    follows_count = mod.get("follows", 0)
    downloads_follows = color_text(f"[ Downloads: {downloads_count:,} | Follows: {follows_count:,} ]", "gray")

    server_side = mod_environment_color(mod["server_side"])
    client_side = mod_environment_color(mod["client_side"])
    description = wrap_text(mod["description"], initial_indent=" ", subsequent_indent="  ")

    print(f"""
{mod_header}
[ {color('bold')}Server: {server_side}{color('reset')} | Client: {client_side} ] {downloads_follows}
> https://modrinth.com/mod/{slug}
{description}""")

def show_mod(args):
  mods = args.mods

  mod = mods[0]
  log.info("Getting mod info...")
  mod_info = json.loads(request_fetch(
    f"https://api.modrinth.com/v2/project/{mod}",
  ))

  name = color_text(mod_info['title'], "bold")
  description = wrap_text(f"Description: {color_text(mod_info['description'], 'bold')}", subsequent_indent=' ')

  slug = color_text(mod_info["slug"], "bold")
  mod_id = color_text(mod_info["id"], "bold")

  downloads = color_text(f"{mod_info['downloads']:,}", "bold")
  followers = color_text(f"{mod_info['followers']:,}", "bold")

  categories = color_text(", ".join(entry.capitalize() for entry in mod_info["categories"]), "bold")
  loaders = color_text(", ".join(entry.capitalize() for entry in mod_info["loaders"]), "bold")
  mc_versions = wrap_text(f"Minecraft Versions {color_text(', '.join(mod_info['game_versions']), 'bold')}", subsequent_indent=" ")

  mod_license = mod_info["license"]
  license_name = color_text(mod_license["name"] or "All Rights Reserved", "bold") 
  license_id = color_text(mod_license["id"], "bold")

  server_side = mod_environment_color(mod_info["server_side"])
  client_side = mod_environment_color(mod_info["client_side"])

  print(f"""Name: {name}
Slug/ID: {slug} ({mod_id})

Downloads: {downloads}
Followers: {followers}

Categories: {categories}
Loaders: {loaders}
Environment: Server: {server_side} | Client: {client_side}
{mc_versions}

License: {license_name} ({license_id})
{description}""")

def start_server(args):
  launcher_config = load_config("launcher")
  memory_limit = launcher_config["ram"]

  jarfile = launcher_config['jarfile']

  if not Path(jarfile).exists():
    raise StartServerError(f"Couldn't find server jarfile '{jarfile}'")

  if memory_limit["min"] > memory_limit["max"]:
    raise StartServerError(f"Minimum RAM cannot be larger that maximum RAM, please check configuration for `launcher`")

  try:
    if not check_eula_agreed():
      log.warning("You need to agree to Mojang's EULA in order to run the server: https://aka.ms/MinecraftEULA")
      log.info(f"Type {color_text(eula_agree_sentence, 'yellow')} (case-sensitive) to agree with Mojang's EULA.")
      answer = input("> ")

      if answer == eula_agree_sentence:
        eula_agree()
      else:
        raise EULAAgreementError("Failed to start the Minecraft server: EULA not agreed")
  except KeyboardInterrupt:
    raise EULAAgreementError("\nFailed to start the Minecraft server: EULA not agreed")

  java_command_argv = [
    "java",
    f"-Xms{memory_limit['min']}M",
    f"-Xmx{memory_limit['max']}M",
    "-jar",
    launcher_config["jarfile"]
  ]

  if launcher_config["hide_gui"]:
    java_command_argv.append("nogui")

  log.info("Starting Minecraft server...")
  log.debug(f"Executing command: {' '.join(java_command_argv)}")
  os.execvp("java", java_command_argv)

# Main
def main():
  if ((sys.argv[1] if len(sys.argv) > 1 else "") == "cake"): hahaha_yes()
  debug_mode = os.getenv("MCSERVER_DEBUG") == "1"
  log_level = log.DEBUG if debug_mode else log.INFO

  log.basicConfig(
    format="[%(levelname)s]: %(message)s",
    level=log_level
  )

  # Parser
  parser = argparse.ArgumentParser(prog="mcserver",
    description="A CLI tool to help managing Minecraft: Java Edition server.",
    epilog="Not created for Windows.")

  parser.add_argument("--version",
    action="version",
    version="%(prog)s " + __version__)

  parser.set_defaults(func=print_help, parser=parser)
  subparsers = parser.add_subparsers(title="Commands")

  # Setup
  #'init' command
  parser_init = subparsers.add_parser("init", help="Initialize MCServer directory")
  parser_init.set_defaults(func=initialize_directory)

  #'install' command
  parser_install = subparsers.add_parser("install", help="Install the server")
  parser_install.set_defaults(func=install_server)

  #'start' command
  parser_start = subparsers.add_parser("start", help="Start the server")
  parser_start.set_defaults(func=start_server)

  # Mod management
  #'add' command
  parser_add = subparsers.add_parser("add", help="Download mod(s) from Modrinth")
  parser_add.add_argument("mods", nargs="+", help="Slug (or ID) of the mod(s)")
  parser_add.set_defaults(func=add_mod)

  #'search' command
  parser_search = subparsers.add_parser("search", help="Search mod(s) from Modrinth")
  parser_search.add_argument("query", nargs="*", help="Query to search")

  parser_search.add_argument("-n", "--no-filter",  action="store_true", help="Do not use any search filters")
  parser_search.add_argument("-p", "--page",default=1,  type=int, help="Page(s) number", metavar="N")

  parser_search.set_defaults(func=search_mod)

  #'show' command
  parser_show = subparsers.add_parser("show", help="Show info about mod(s)")
  parser_show.add_argument("mods", help="Slug (or ID) of the mod(s)", nargs="+")
  parser_show.set_defaults(func=show_mod)

  args = parser.parse_args()

  # Let it crash
  if debug_mode:
   args.func(args)
  else:
    try:
      args.func(args)
    except Exception as error:
      log.error(error)

if __name__ == "__main__": main()
