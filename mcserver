# Color functions
def ansi(name):
  if isatty:
    return ansi_codes.get(name, "")
  return ""

def color_string(string, color_name):
  return f"{ansi(color_name)}{string}{ansi('reset')}"

def mod_environment_color(environment: str, padding: int = 0):
  if environment == "required":
    return color_string(f"{'Required': <{padding}}", "green")
  elif environment == "optional":
    return color_string(f"{'Optional': <{padding}}", "yellow")
  elif environment == "unsupported":
    return color_string(f"{'Unsupported': <{padding}}", "red")
  elif environment == "unknown":
    return color_string(f"{'Unknown': <{padding}}", "gray")
  return f"{environment: <{padding}}"

