def merge_dict(base, update):
  for key, value in update.items():
    if key in base and isinstance(base[key], dict) and isinstance(value, dict):
      merge_dict(base[key], value)
    elif value is None:
      pass
    else:
      base[key] = value

def format_number(number, unit_type="si"):
  unit_multiples = 0
  prefixes = 0

  if unit_type == "si":
    unit_multiples = 1_000
    prefixes = si_prefixes
  elif unit_type == "iec":
    unit_multiples = 1_024
    prefixes = iec_prefixes
  else:
    raise ValueError(f"'{unit_type}' is not a valid number unit type")

  iteration = 0
  while number >= unit_multiples:
    if iteration > len(prefixes) - 2:
      break

    number /= unit_multiples
    iteration += 1

  #Whoa, a hack!
  number_string = str(f"{number:.2f}").removesuffix("0").removesuffix(".0")
  return f"{number_string}{prefixes[iteration]}"

def wrap_text(text, initial_indent="", subsequent_indent=""):
  if not isinstance(initial_indent, str):
    raise ValueError(f"initial_indent must be str, not {type(initial_indent)}")
  elif not isinstance(subsequent_indent, str):
    raise ValueError(f"subsequent_indent must be str, not {type(subsequent_indent)}")

  terminal_width = shutil.get_terminal_size().columns
  return "\n".join(textwrap.wrap(text, width=terminal_width, initial_indent=initial_indent, subsequent_indent=subsequent_indent))

# Config functions
def generate_config(config_name, update_config=None):
  if update_config is None:
    update_config = {}

  config_filename = f"{config_name}.json"
  config_path = configs_dir / config_filename

  config_content = None

  try:
    config_content = copy.deepcopy(default_configs[config_name])
  except KeyError as error:
    raise ValueError(f"Failed to generate configuration file for '{config_name}': No default configuration available") from error

  merge_dict(config_content, update_config)

  try:
    with open(config_path, mode="xt") as config_file:
      json.dump(
        config_content,
        config_file,
        indent=2
      )
  except FileExistsError as error:
    raise FileExistsError(f"Cannot create configuration file for '{config_name}': File already exists") from error
  except FileNotFoundError as error:
    raise FileNotFoundError(f"Cannot create configuration file for '{config_name}': Configuration directory does not exist") from error
  except IsADirectoryError as error:
    raise IsADirectoryError(f"Cannot create configuration file for '{config_name}': Directory with same name already exists") from error
  except PermissionError as error:
    raise PermissionError(f"Cannot create configuration file for '{config_name}': Permission denied to create file") from error

def load_config(config_name):
  config_filename = f"{config_name}.json"
  config_path = configs_dir / config_filename

  try:
    with open(config_path, mode="rt") as config_file:
      return json.load(config_file)
  except json.JSONDecodeError as error:
    msg = error.msg
    lineno = error.lineno
    colno = error.colno

    raise ValueError(f"Failed to load configuration for `{config_name}`: {msg} at line {lineno} column {colno}") from error

  except FileNotFoundError as error:
    raise FileNotFoundError(f"Cannot read configuration file for '{config_name}': Configuration file does not exist") from error
  except IsADirectoryError as error:
    raise IsADirectoryError(f"Cannot read configuration file for '{config_name}': Not a file (is a directory)") from error
  except PermissionError as error:
    raise PermissionError(f"Cannot read configuration file for '{config_name}': Permission denied to read file") from error

# Requests
def fetch_url(url: str, params: dict = None, headers: dict = None, timeout: int =10):
  if params is None: params = {}
  if headers is None: headers = {}
  headers.setdefault("User-Agent", user_agent)

  query_string = f"?{urllib.parse.urlencode(params)}" if params else ""
  request_url = urllib.request.Request(f"{url}{query_string}", headers=headers, method="GET")

  log.debug(f"Fetching URL: {request_url.full_url}")

  with urllib.request.urlopen(request_url, timeout=timeout) as response:
    return response.read().decode("utf-8")

def download_url(url: str, filename: str | Path, hashes: dict = None, headers: dict = None, timeout: int = 10):
  filename = Path(filename)
  if hashes is None: hashes = {}
  if headers is None: headers = {}
  headers.setdefault("User-Agent", user_agent)

  request_url = urllib.request.Request(url, headers=headers, method="GET")
  tempfile = tempfiles_dir / filename.name

  log.debug(f"Downloading URL: {request_url.full_url}")
  log.debug(f"Temporary file: {tempfile}")

  hash_algorithm = None
  hash_name = None
  expected_hash = None

  if hashes.get("sha512"):
    hash_algorithm = hashlib.sha512()
    hash_name = "sha512"
  elif hashes.get("sha1"):
    hash_algorithm = hashlib.sha1()
    hash_name = "sha1"

  if hash_name:
    expected_hash = hashes[hash_name]
    log.debug(f"Calculating hash {hash_name} while downloading...")
    log.debug(f"Expected {hash_name}: {expected_hash}")

  with urllib.request.urlopen(request_url, timeout=timeout) as response:
    with open(tempfile, mode="wb") as file:
      while True:
        data = response.read(read_chunk_size)

        if not data:
          break

        if hash_algorithm:
          hash_algorithm.update(data)

        file.write(data)

    if hash_algorithm:
      calculated_hash = hash_algorithm.hexdigest()

      log.debug(f"Got hash: {calculated_hash}")
      if calculated_hash != expected_hash:
        raise DownloadURLError(f"Downloaded file '{tempfile.relative_to(current_dir)}' hash does not match with the expected {hash_name} hash")

  shutil.move(tempfile, filename)

# Mod Versions
def fetch_mod_version(modid: str, game_versions: list, loaders: list):
  response = json.loads(fetch_url(f"https://api.modrinth.com/v2/project/{modid}/version", params={
    "loaders": json.dumps(loaders),
    "game_versions": json.dumps(game_versions),
    "include_changelog": "false"
  }))

  if not response:
    raise FetchModVersionError(f"No version found in mod '{modid}' for loaders {', '.join(loaders).title()}, Minecraft version {', '.join(game_versions)}")

  selected_version = response[0]

  selected_file = None
  for file in selected_version["files"]:
    if file["primary"]:
      selected_file = file
      break

  if selected_file is None:
    raise FetchModVersionError(f"This version of the mod '{modid}' does not have any file marked primary")

  dependencies = []
  for dependency in selected_version["dependencies"]:
    dependencies.append({
      "id": dependency["project_id"],
      "type": dependency["dependency_type"]
    })

  return {
    "data": {
      "version_id": selected_version["id"],
      "id": selected_version["project_id"],
      "name": selected_version["name"],
      "version_number": selected_version["version_number"],
      "version_type": selected_version["version_type"],
      "file": {
        "hashes": selected_file["hashes"],
        "url": selected_file["url"],
        "filename": selected_file["filename"],
        "size": selected_file["size"]
      }
    },
    "dependencies": dependencies
  }

def resolve_mods_dependencies(mods_id: list, game_version: str, loader_name: str):
  # Initialize variables
  unresolved_dependencies = []
  resolved_dependecies = set()

  dependencies_data = []
  incompatible_dependencies = set()

  # Fetch initial mods info
  for mod in mods_id:
    # Mark any "dependency" as manual if matches `mod_id`
    for dependency_data in dependencies_data:
      if dependency_data["id"] == mod:
        log.debug(f"Marking a mod type as 'manual': {mod}")
        dependency_data["type"] = "manual"
        break

    # Check if mod is already resolved
    if mod in resolved_dependecies:
      log.debug(f"Skipping already resolved mod: {mod}")
      continue

    # Getting mod version info
    log.debug(f"Getting mod version information of {mod}...")
    version_info = fetch_mod_version(mod, [game_version], [loader_name])

    version_data = version_info["data"]
    version_dependencies = version_info["dependencies"]

    # Append data to `mods_data` such as dependency type and file
    version_data["type"] = "manual"
    dependencies_data.append(version_data)

    # Make sure the mod doesn't get fetched again
    log.debug(f"Adding mod as resolved dependencies: {mod}")
    resolved_dependecies.update({ mod, version_data["id"] })

    # Add dependencies to `unresolved_dependencies`
    for dependency in version_dependencies:
      dependency_id = dependency["id"]

      if dependency_id in resolved_dependecies:
        log.debug(f"Skipping already resolved dependency: {dependency_id}")
      else:
        log.debug(f"Adding mod as unresolved dependency: {dependency_id}")
        unresolved_dependencies.append(dependency)

  # Fetch the rest of the dependencies info
  while unresolved_dependencies:
    dependency = unresolved_dependencies.pop(0)

    dependency_id = dependency["id"]
    dependency_type = dependency["type"]

    # Check if dependency is already resolved, skip (remove from `unresolved_dependencies`)
    if dependency_id in resolved_dependecies:
      log.debug(f"Dependency already resolved: {dependency_id}")
      continue

    # Check if dependency is already marked as 'incompatible'
    if dependency_id in incompatible_dependencies:
      log.debug(f"Dependency is marked as 'incopatible': {dependency_id}, not processing")
      continue

    # Check if dependency is marked as 'incompatible'
    if dependency_type == "incompatible":
      log.warning(f"Dependency is marked as 'incompatible': {dependency_id}, adding to `incompatible_dependencies`")
      incompatible_dependencies.add(dependency_id)
      continue

    # Skip processing for 'embedded' dependency, skip (remove from `unresolved_dependencies`)
    if dependency_type == "embedded":
      log.debug(f"Dependency is marked as 'embedded': {dependency_id}, skipping")
      continue

    log.debug(f"Resolving dependency version information of {dependency_id}...")

    # Try fetch dependency version
    dependency_version = None
    try:
      dependency_version = fetch_mod_version(dependency_id, [game_version], [loader_name])
    except FetchModVersionError as error:
      if dependency_type == "optional":
        log.warning(f"An optional dependency doesn't have version for {loader_name.capitalize()}, Minecraft {game_version}.")
        continue

      raise ResolveModsDependenciesError("No version found for dependency") from error

    # Append dependency type in data
    version_data = dependency_version["data"]
    version_dependencies = dependency_version["dependencies"]

    # Append dependency data to dependencies_data
    version_data["type"] = dependency_type
    dependencies_data.append(version_data)

    # Add dependency as resolved
    resolved_dependecies.update({ version_data["id"], dependency_id })

    # Dependency squared
    for dependency2 in version_dependencies:
      dependency2_id = dependency2["id"]

      if dependency2_id in resolved_dependecies:
        log.debug(f"Skipping already resolved dependency: {dependency2_id}")
      else:
        log.debug(f"Adding dependency2 as unresolved dependency: {dependency2_id}")
        unresolved_dependencies.append(dependency2)
  
  return {
    "dependencies_data": dependencies_data,
    "incompatible_dependencies": incompatible_dependencies
  }

# EULA functions
def check_eula_agreed():
  try:
    with open("eula.txt") as file:
      for line in file.readlines():
        if line.startswith("eula=true"):
          return True
  except FileNotFoundError:
    pass

  return False

