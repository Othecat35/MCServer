# Color functions
def ansi(name):
  if isatty:
    return ansi_codes.get(name, "")
  return ""

def color_string(string, color_name):
  return f"{ansi(color_name)}{string}{ansi('reset')}"

def mod_environment_color(environment):
  if environment == "required":
    return color_string("Required", "green")
  elif environment == "optional":
    return color_string("Optional", "yellow")
  elif environment == "unsupported":
    return color_string("Unsupported", "red")
  elif environment == "unknown":
    return color_string("Unknown", "gray")
  return environment

