# Command functions
def add_mod(args):
  mods = args.mods

  server_config = load_config("server")
  server_loader = server_config["loader"]

  loader_name = server_loader["name"]
  server_version = server_config["version"]

  if server_loader["name"] == "vanilla":
    raise AddModError("Vanilla Minecraft server does not support mod")

  print()
  resolved_dependencies = resolve_mods(mods, server_version, loader_name, lambda resolved, unresolved: print_status("Resolving mod dependencies...", dynamic=f"Resolving mod dependencies... {resolved} out of {unresolved} done"))
  resolved_data = resolved_dependencies["dependencies_data"]

  # Get mod IDs
  mod_ids = []
  total_size = 0

  required_mod_ids = set()
  optional_mod_ids = set()

  for mod in resolved_data:
    if mod["type"] in ("required", "manual"):
      required_mod_ids.add(mod["id"])
    elif mod["type"] == "optional":
      optional_mod_ids.add(mod["id"])

    total_size += mod["file"]["size"]
    mod_ids.append(mod["id"])

  response = json.loads(fetch_url("https://api.modrinth.com/v2/projects", params={
    "ids": json.dumps(mod_ids)
  }))

  optional_modname_list = []
  required_modname_list = []

  for mod in response:
    if mod["id"] in required_mod_ids:
      required_modname_list.append(f"{mod['title']} ({mod['slug']})")
    elif mod['id'] in optional_mod_ids:
      optional_modname_list.append(f"{mod['title']} ({mod['slug']})")

  log.info("The mod(s) that are going to be downloaded:")
  print(wrap_text(", ".join(required_modname_list), initial_indent="  ", subsequent_indent="  "))

  if optional_mod_ids:
    log.info("The mod(s) that are optional:")
    print(wrap_text(", ".join(optional_modname_list), initial_indent="  ", subsequent_indent="  "))

  print()
  log.info(f"Will download {format_number(total_size, 'iec')} worth of file(s) [including optional, but not going to download optional].")

  continue_action = True
  answer = " "

  try:
    answer = input("Do you want to continue? [Y/n] ")
  except KeyboardInterrupt:
    continue_action = False

  match answer.lower():
    case "y" | "yes" | "":
      pass
    case "n" | "no" | _:
      continue_action = False

  if not continue_action:
    raise AddModError("Cancelled")

  mods_dir.mkdir(exist_ok=True)
  for mod in resolved_data:
    if mod["type"] in ("required", "manual"):
      mod_file = mod["file"]

      log.info(f"Downloading version {mod['name']}...")
      download_url(mod_file["url"], mods_dir / mod_file["filename"], hashes=mod_file["hashes"])

def initialize_server(args):
  mc_version = args.mc_version

  loader = args.loader
  loader_version = args.loader_version

  min_ram = args.min_ram
  max_ram = args.max_ram

  if not mcserver_dir.exists():
    log.info(f"Initializing server configuration...")
  else:
    log.info(f"Reinitializing server confuguration...")

  mcserver_dir.mkdir(exist_ok=True)

  configs_dir.mkdir(exist_ok=True)
  tempfiles_dir.mkdir(exist_ok=True)

  if mc_version is None:
    log.info("Getting Mojang game version manifest...")
    latest_version = json.loads(fetch_url("https://launchermeta.mojang.com/mc/game/version_manifest.json"))["latest"]["release"]

    log.info(f"'--mc-version' was not specified, setting it to {latest_version} (the latest release version)")
    mc_version = latest_version

  if (loader != "vanilla") and not loader_version:
    raise InitializeServerError("--loader and --loader-version must be set together")

  for config in default_configs.keys():
    update_values = {}
    if config == "launcher":
      update_values = {
        "ram": {
          "min": min_ram,
          "max": max_ram
        }
      }

    if config == "server":
      update_values = {
        "version": mc_version,
        "loader": {
          "name": loader,
          "version": loader_version
        }
      }

    try:
      generate_config(config, update_config=update_values)
    except FileExistsError:
      log.debug(f"Configuration file for `{config}` already exists, not regenerating")

def install_server(args):
  server_config = load_config("server")
  launcher_config = load_config("launcher")

  server_loader = server_config["loader"]
  server_version = server_config["version"]

  loader_name = server_loader["name"]
  loader_version = server_loader["version"]

  match loader_name:
    case "fabric":
      log.info(f"Downloading Fabric loader {loader_version} for Minecraft server {server_version}...")
      download_url(f"https://meta.fabricmc.net/v2/versions/loader/{server_version}/{loader_version}/1.1.1/server/jar", launcher_config["jarfile"])
    case "vanilla":
      log.info("Getting Mojang game version manifest...")
      version_manifest = json.loads(fetch_url("https://launchermeta.mojang.com/mc/game/version_manifest.json"))

      selected_version_url = None
      for version in version_manifest["versions"]:
        if version["id"] == server_version:
          selected_version_url =  version["url"]
          break

      server_download = json.loads(fetch_url(selected_version_url))["downloads"]["server"]
      log.info(f"Downloading jarfile for vanilla Minecraft server {server_version}...")

      download_url(server_download["url"], launcher_config["jarfile"], hashes={
        "sha1": server_download["sha1"]
      })
    case _:
      raise InstallServerError(f"Server loader '{loader_name}' is not supported")

  log.info("Server installation is complete.")

def search_mod(args):
  query = " ".join(args.query)
  no_filter = args.no_filter

  page = args.page
  sort_by = args.sort_by

  modrinth_config = load_config("modrinth")
  server_config = None

  search_index = sort_by or modrinth_config.get("sort_by", "relevance")

  search_filters = None
  search_message = None

  if no_filter:
    search_message = f"Searching mods with '{query}' in Modrinth sorted by {search_index}..."
    search_filters = [["project_type:mod"]]
  else:
    server_config = load_config("server")
    server_loader = server_config["loader"]

    server_version = server_config["version"]
    loader_name = server_loader["name"]

    if loader_name == "vanilla":
      raise SearchModError("Vanilla Minecraft server does not support mod")

    search_message = f"Searching mods with '{query}' in Modrinth for {loader_name.capitalize()}, Minecraft server {server_version} sorted by {search_index}..."
    search_filters = [
      ["project_type:mod"],
      ["server_side!=unsupported"],
      [f"categories:{loader_name}"],
      [f"versions:{server_version}"]
    ]

  search_limit = modrinth_config["search_limit"]
  search_offset = search_limit * (page - 1)

  log.info(search_message)

  response = json.loads(fetch_url(
    "https://api.modrinth.com/v2/search",
    {
      "query": query,
      "facets": json.dumps(search_filters),
      "index": search_index,
      "limit": search_limit,
      "offset": search_offset
    }
  ))

  mods_list = response.get("hits", [])
  if not mods_list:
    raise SearchModError(f"No mod found")

  total_hits = response.get('total_hits', 0)
  total_pages = f"{math.ceil(total_hits / search_limit):,}"

  response_offset = response.get("offset", 0)
  shown_mods_count = min(len(mods_list), search_limit)

  skipped_message = f"(skipped {response_offset:,} mod(s)) " if response_offset > 0 else ""
  log.info(f"Showing {shown_mods_count:,} mod(s) out of {total_hits:,} total mod(s) {skipped_message}| Page: {page:,}/{total_pages}")

  for mod in mods_list:
    title = color_string(mod.get("title", ""), "bold")
    slug = mod.get("slug", "")
    author = f"by {mod.get('author', '')}"

    mod_header = wrap_text(f"{title} ({slug}) {color_string(author, 'gray')}", subsequent_indent=" ")

    downloads = format_number(mod.get("downloads", 0))
    follows = format_number(mod.get("follows", 0))
    downloads_follows = color_string(f"[ Downloads: {downloads} | Follows: {follows} ]", "gray")

    server_side = color_string(f"Server: {mod_environment_color(mod['server_side'])}", "bold")
    client_side = mod_environment_color(mod["client_side"])
    description = wrap_text(mod["description"], initial_indent=" ", subsequent_indent="  ")

    print(f"""
{mod_header}
[ {server_side} | Client: {client_side} ] {downloads_follows}
> https://modrinth.com/mod/{slug}
{description}""")

def show_mod(args):
  mods = args.mods

  log.info("Getting mod(s) information...")
  mods_info = json.loads(fetch_url(
    "https://api.modrinth.com/v2/projects",
    params={
      "ids": json.dumps(mods)
    }
  ))

  mod_index = 0
  for mod in mods_info:
    title = color_string(mod.get("title", "") or "<No Title>", "bold")
    slug = color_string(mod.get("slug", f"<{mods[mod_index]}>"), "bold")

    downloads = color_string(format_number(mod.get("downloads", 0)), "bold")
    followers = color_string(format_number(mod.get("followers", 0)), "bold")

    mod_categories = ', '.join(mod.get('categories', ['None'])).title()
    categories = wrap_text(f"Categories: {color_string(mod_categories, 'bold')}", subsequent_indent="  ")

    mod_loaders = ', '.join(mod.get('loaders', ['None'])).title()
    loaders = wrap_text(f"Loaders: {color_string(mod_loaders, 'bold')}", subsequent_indent="  ")

    mod_game_versions = ', '.join(mod.get('game_versions', ['None'])).title()
    game_versions = wrap_text(f"Minecraft Versions: {color_string(mod_game_versions, 'bold')}", subsequent_indent="  ")

    server_side = color_string(f"Server: {mod_environment_color(mod.get('server_side', '<Unknown>'))}", "bold")
    client_side = mod_environment_color(mod.get("client_side", "<Unknown>"))

    mod_license = mod.get("license", {})
    license_name = color_string(mod_license.get("name", "") or "All Rights Reserved", "bold")
    license_id = color_string(mod_license.get("id", "") or "LicenseRef-All-Rights-Reserved", "bold")

    mod_description = mod.get('description', '<No Description>')
    description = wrap_text(f"Description: {color_string(mod_description, 'bold')}", subsequent_indent="  ")

    if (mod_index >= 1): print()
    print(f"""Name: {title} ({slug})
Downloads: {downloads}
Followers: {followers}
{categories}
{loaders}
{game_versions}
Environment: {server_side} | Client: {client_side}
License: {license_name} ({license_id})
{description}""")

    mod_index += 1

def start_server(args):
  launcher_config = load_config("launcher")
  memory_limit = launcher_config["ram"]

  jarfile = launcher_config['jarfile']

  if not Path(jarfile).exists():
    raise StartServerError(f"Couldn't find server jarfile '{jarfile}'")

  if memory_limit["min"] > memory_limit["max"]:
    raise StartServerError(f"Minimum RAM cannot be larger that maximum RAM, please check configuration for `launcher`")

  try:
    if not check_eula_agreed():
      log.warning("You need to agree to Mojang's EULA in order to run the server: https://aka.ms/MinecraftEULA")
      log.info(f"Type {color_string(eula_agree_sentence, 'yellow')} (case-sensitive) to agree with Mojang's EULA.")
      answer = input("> ")

      if answer == eula_agree_sentence:
        eula_agree()
      else:
        raise EULAAgreementError("Failed to start the Minecraft server: EULA not agreed")
  except KeyboardInterrupt:
    raise EULAAgreementError("\nFailed to start the Minecraft server: EULA not agreed")

  java_command_argv = [
    "java",
    f"-Xms{memory_limit['min']}M",
    f"-Xmx{memory_limit['max']}M",
    "-jar",
    launcher_config["jarfile"]
  ]

  if launcher_config["hide_gui"]:
    java_command_argv.append("nogui")

  log.info("Starting Minecraft server...")
  log.debug(f"Executing command: {' '.join(java_command_argv)}")
  os.execvp("java", java_command_argv)

# Main
def main():
  if ((sys.argv[1] if len(sys.argv) > 1 else "") == "cake"): hahaha_yes()

  log.basicConfig(
    format="[%(levelname)s]: %(message)s",
    level=log_level
  )

  # Parser
  parser = argparse.ArgumentParser(prog="mcserver",
    description="A CLI tool to help managing Minecraft: Java Edition server.",
    epilog="Not created for Windows.")

  parser.add_argument("--version",
    action="version",
    version="%(prog)s " + __version__)

  parser.set_defaults(func=print_help, parser=parser)
  subparsers = parser.add_subparsers(title="Commands")

  #Setup
  # 'init' command
  parser_init = subparsers.add_parser("init", help="Initialize server configuration")

  parser_init.add_argument("--mc-version", help="Version of the Minecraft server", metavar="version") # Auto fetch latest when None (or not specified)

  parser_init.add_argument("--loader", choices=loaders_list, default="vanilla", help="Mod loader for the server (vanilla for unmodded server)")
  parser_init.add_argument("--loader-version", help="Version of the server's mod loader (not checked if exists)", metavar="version")

  parser_init.add_argument("--min-ram", default=512, type=int, help="Minimum RAM for server (in Mebibyte)", metavar="size")
  parser_init.add_argument("--max-ram", default=2048, type=int, help="Maximum RAM for server (in Mebibyte)", metavar="size")
  parser_init.set_defaults(func=initialize_server)

  # 'install' command
  parser_install = subparsers.add_parser("install", help="Install the server")
  parser_install.set_defaults(func=install_server)

  # 'start' command
  parser_start = subparsers.add_parser("start", help="Start the server")
  parser_start.set_defaults(func=start_server)

  #Mod management
  # 'add' command
  parser_add = subparsers.add_parser("add", help="Add mod(s) from Modrinth")
  parser_add.add_argument("mods", nargs="+", help="Slug (or ID) of the mod(s)")
  parser_add.set_defaults(func=add_mod)

  # 'search' command
  parser_search = subparsers.add_parser("search", help="Search mods in Modrinth")
  parser_search.add_argument("query", nargs="*", help="Query to search")
  parser_search.add_argument("-n", "--no-filter",  action="store_true", help="No search filter when searching")

  parser_search.add_argument("-p", "--page", default=1, type=int, help="Page number", metavar="N")
  parser_search.add_argument("-s", "--sort-by", choices=["downloads", "follows", "newest", "relevance", "updated"], type=str, help="Sort the result with", metavar="S")

  parser_search.set_defaults(func=search_mod)

  # 'show' command
  parser_show = subparsers.add_parser("show", help="Show information about mod(s) from Modrinth")
  parser_show.add_argument("mods", help="Slug (or ID) of the mod(s)", nargs="+")
  parser_show.set_defaults(func=show_mod)

  args = parser.parse_args()

  # Let it crash
  if debug_mode:
    args.func(args)
  else:
    try:
      args.func(args)
    except Exception as error:
      log.error(error)
      sys.exit(1)

if __name__ == "__main__":
  main()

